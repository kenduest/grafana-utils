            "--basic-auth-password",
            "--http-header",
            "--tls-skip-verify",
            "--server-name"
          ],
          "presetProfiles": [
            "starter"
          ],
          "addDefaults": {
            "access": "proxy",
            "jsonData": {
              "nodeGraph": {
                "enabled": true
              },
              "traceQuery": {
                "timeShiftEnabled": true
