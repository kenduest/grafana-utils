            }
          },
          "fullAddDefaults": {
            "access": "proxy",
            "jsonData": {
              "nodeGraph": {
                "enabled": true
              },
              "traceQuery": {
                "timeShiftEnabled": true
              }
            }
          }
        },
        {
          "type": "zipkin",
          "profile": "tracing-http",
          "queryLanguage": "trace-search",
          "requiresDatasourceUrl": true,
          "suggestedFlags": [
            "--basic-auth",
            "--basic-auth-user",
            "--basic-auth-password",
            "--http-header",
            "--tls-skip-verify",
            "--server-name"
          ],
          "presetProfiles": [
            "starter"
          ],
          "addDefaults": {
            "access": "proxy",
            "jsonData": {
              "nodeGraph": {
                "enabled": true
              },
              "traceQuery": {
                "timeShiftEnabled": true
              }
            }
          },
          "fullAddDefaults": {
            "access": "proxy",
            "jsonData": {
              "nodeGraph": {
                "enabled": true
              },
              "traceQuery": {
                "timeShiftEnabled": true
              }
            }
          }
        },
        {
          "type": "tempo",
          "profile": "tracing-http",
          "queryLanguage": "traceql",
          "requiresDatasourceUrl": true,
          "suggestedFlags": [
            "--basic-auth",
            "--basic-auth-user",
            "--basic-auth-password",
            "--http-header",
            "--tls-skip-verify",
            "--server-name"
          ],
          "presetProfiles": [
            "starter",
            "full"
          ],
          "addDefaults": {
            "access": "proxy",
            "jsonData": {
              "nodeGraph": {
                "enabled": true
              },
              "traceQuery": {
                "timeShiftEnabled": true,
                "spanStartTimeShift": "-1h",
                "spanEndTimeShift": "1h"
              },
              "search": {
                "hide": false
              },
              "streamingEnabled": {
                "search": true
              }
            }
          },
          "fullAddDefaults": {
            "access": "proxy",
            "jsonData": {
              "nodeGraph": {
                "enabled": true
              },
              "traceQuery": {
                "timeShiftEnabled": true,
                "spanStartTimeShift": "-1h",
                "spanEndTimeShift": "1h"
              },
              "search": {
                "hide": false
              },
              "streamingEnabled": {
                "search": true
              },
              "serviceMap": {
                "datasourceUid": "prometheus"
              },
              "tracesToLogsV2": {
                "datasourceUid": "loki",
                "spanStartTimeShift": "-1h",
                "spanEndTimeShift": "1h"
              },
              "tracesToMetrics": {
                "datasourceUid": "prometheus",
                "spanStartTimeShift": "-1h",
                "spanEndTimeShift": "1h"
              }
            }
          }
        }
      ]
    },
