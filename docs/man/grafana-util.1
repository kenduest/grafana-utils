.TH GRAFANA-UTIL 1 "2026-04-03" "grafana-util 0.10.0" "User Commands"
.SH NAME
grafana\-util \- review Grafana changes before applying them
.SH SYNOPSIS
.B grafana-util [\fB\-\-help\fR] [\fB\-\-version\fR]
.PP
.B grafana-util \fICOMMAND\fR [\fISUBCOMMAND\fR] [\fIOPTIONS\fR]
.PP
.B grafana-util dashboard [\fISUBCOMMAND\fR] [\fIOPTIONS\fR]
.PP
.B grafana-util alert [\fISUBCOMMAND\fR] [\fIOPTIONS\fR]
.PP
.B grafana-util datasource [\fISUBCOMMAND\fR] [\fIOPTIONS\fR]
.PP
.B grafana-util access [\fISUBCOMMAND\fR] [\fIOPTIONS\fR]
.PP
.B grafana-util config [\fISUBCOMMAND\fR] [\fIOPTIONS\fR]
.PP
.B grafana-util status [\fISUBCOMMAND\fR] [\fIOPTIONS\fR]
.PP
